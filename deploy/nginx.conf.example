# Пример конфига Nginx как обратный прокси перед Next.js (PM2 слушает
# на 127.0.0.1:3000). Подставьте свой домен и путь к SSL-сертификатам
# (Beget обычно выдаёт бесплатный SSL через Let's Encrypt автоматически
# при подключении домена — certbot настроит эти строки сам).
#
# Скопируйте на сервер, например, в /etc/nginx/sites-available/agalife.conf
# и создайте символическую ссылку в sites-enabled, затем
# `nginx -t && systemctl reload nginx`.

server {
    listen 80;
    server_name agalife.ru www.agalife.ru;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
