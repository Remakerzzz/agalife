NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Адрес сайта в проде — используется в robots.txt/sitemap.xml и ссылках
# соцсетей. Укажите настоящий домен (или *.vercel.app, если своего пока нет).
NEXT_PUBLIC_SITE_URL=https://agalife.vercel.app

# Код подтверждения прав на сайт из Яндекс.Вебмастера (Настройки ->
# Подтверждение прав, способ "Мета-тег"). Без него сайт не появится в
# поиске Яндекса — см. README для пошаговой инструкции.
NEXT_PUBLIC_YANDEX_VERIFICATION=
